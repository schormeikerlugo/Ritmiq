# Dejamos apps/desktop intacto en el filesystem para que pnpm pueda resolver
# el workspace. El postinstall de desktop detecta Vercel via env y se salta
# los pasos nativos. Solo excluimos artefactos pesados.

apps/desktop/bin
apps/desktop/release
apps/desktop/dist
apps/desktop/dist-electron
apps/desktop/renderer/dist

# Supabase (CLI sube migraciones aparte)
supabase

# Documentación y planes
docs
.opencode

# Build artifacts y logs
.turbo
*.log
*.sqlite

# Entornos locales (Vercel pone los suyos en su panel)
.env
.env.development
.env.local
.env.cloud
