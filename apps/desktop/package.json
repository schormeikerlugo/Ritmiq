{
  "name": "@ritmiq/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on tcp:5174 && electron .\"",
    "dev:cloud": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite --mode production\" \"wait-on tcp:5174 && electron .\"",
    "postinstall": "node scripts/postinstall.js",
    "fetch:ytdlp": "node scripts/fetch-ytdlp.js",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "vite build && electron-builder --linux",
    "build:linux": "vite build && electron-builder --linux",
    "build:dir": "vite build && electron-builder --linux --dir"
  },
  "dependencies": {
    "@ritmiq/api": "workspace:*",
    "@ritmiq/core": "workspace:*",
    "@ritmiq/db": "workspace:*",
    "@ritmiq/ui": "workspace:*",
    "@ritmiq/yt": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "bonjour-service": "^1.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.ritmiq.app",
    "productName": "Ritmiq",
    "asar": true,
    "files": [
      "main/**/*",
      "preload/**/*",
      "renderer/dist/**/*",
      "scripts/fetch-ytdlp.js",
      "scripts/fetch-cloudflared.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin/yt-dlp",
        "to": "bin/yt-dlp"
      },
      {
        "from": "bin/cloudflared",
        "to": "bin/cloudflared"
      },
      {
        "from": "build-resources/icon.png",
        "to": "build-resources/icon.png"
      },
      {
        "from": "../../.env.production",
        "to": ".env.production"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo",
      "executableName": "ritmiq",
      "synopsis": "Reproductor de música personal con sync cloud",
      "description": "Ritmiq — reproductor de música multiplataforma con yt-dlp embebido y sync con Supabase.",
      "icon": "build-resources/icon.png"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    }
  }
}
