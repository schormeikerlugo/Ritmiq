# Ritmiq Server (headless 24/7) — variables de entorno
# Copia a `.env` en el directorio del servidor o expórtalas vía systemd.

# ── Datos y red ──────────────────────────────────────────────────────
# Carpeta writable donde se guarda SQLite, cookies, tokens y audio cacheado.
RITMIQ_DATA_DIR=/var/lib/ritmiq

# Puerto HTTP del LAN server (default 3939, igual que el desktop).
RITMIQ_PORT=3939

# ── Firmas de stream (DEBE coincidir con la Edge Function sign-stream) ─
# Sin este secreto, el server rechaza /stream salvo ACCEPT_UNSIGNED.
RITMIQ_STREAM_SIGNING_SECRET=

# Modo compat: acepta requests /stream sin firma (device token / owner).
# Útil mientras no se migra a firmas HMAC en todos los clientes.
RITMIQ_ACCEPT_UNSIGNED_STREAMS=true

# ── yt-dlp ───────────────────────────────────────────────────────────
# Ruta explícita al binario yt-dlp (si no está en PATH).
# RITMIQ_YTDLP_PATH=/usr/local/bin/yt-dlp

# Navegador del que extraer cookies de YouTube (cuenta del DUEÑO del server).
# En Docker NO hay navegador → usa 'none' y monta un archivo de cookies:
RITMIQ_YTDLP_COOKIES_BROWSER=none

# Archivo de cookies Netscape (export de tu navegador). En Docker móntalo
# como volumen y apunta aquí. Es el fallback de cookies del dueño.
# RITMIQ_YTDLP_COOKIES_FILE=/data/owner-cookies.txt

# ── Cookies por usuario (Fase 3) ─────────────────────────────────────
# Clave para cifrar en reposo las cookies de cada usuario (AES-256-GCM).
# Si no se define, se guardan en texto plano con permisos 0600.
RITMIQ_COOKIES_KEY=

# Imagen del contenedor de login por navegador (noVNC). Constrúyela con:
#   docker build -f apps/login-agent/Dockerfile -t ritmiq-login:latest .
RITMIQ_LOGIN_IMAGE=ritmiq-login:latest

# ── Control de acceso (Fase 3c/4) ────────────────────────────────────
# Cuentas Supabase de confianza que se AUTO-APRUEBAN al parear (sin PIN).
# Lista separada por comas de user_id VERIFICADO (el `sub` del JWT).
# Vacío = todos los dispositivos requieren aprobación manual (panel/CLI/desktop).
RITMIQ_ALLOWED_USERS=

# ── Identidad Supabase / seguridad de pareo (Fase 4) ─────────────────
# El servidor verifica el JWT de Supabase para confiar en la identidad del
# cliente (evita suplantar supabase_user_id). Con VITE_SUPABASE_URL definido
# (abajo) verifica contra el JWKS del proyecto (ES256, recomendado, sin
# secreto). Solo define esto si tu proyecto firma con HS256 (clave simétrica
# legacy):
# RITMIQ_SUPABASE_JWT_SECRET=
#
# Exigir login (JWT válido) para poder parear. Por defecto ON cuando la
# verificación JWT está configurada. Ponlo en false para permitir pareo sin
# cuenta (aprobación manual, modo invitado):
# RITMIQ_REQUIRE_AUTH_FOR_PAIR=true

# Runtime JS para resolver el signature/n-challenge de YouTube (obligatorio
# para reproducción fiable). deno o node. Ej: deno:/usr/bin/deno
RITMIQ_YTDLP_JS_RUNTIME=deno:/usr/bin/deno

# Concurrencia máxima de procesos yt-dlp (resoluciones/prewarms en paralelo).
# Por defecto escala con los cores (mitad, acotado 3-8). Súbelo en servidores
# con muchos cores para prewarmear más resultados sin penalizar el play.
# RITMIQ_YTDLP_CONCURRENCY=8

# ── Cache global de URLs (opcional, Supabase Edge) ───────────────────
# Publica URLs resueltas al cache compartido para acelerar a otros clientes.
RITMIQ_PUBLISH_URL_CACHE=true

# ── Cloudflare Tunnel (acceso fuera de la LAN) ───────────────────────
# Named Tunnel (RECOMENDADO, URL fija): pega el token del túnel de Cloudflare.
#   Se crea en dash.cloudflare.com > Zero Trust > Networks > Tunnels.
RITMIQ_TUNNEL_TOKEN=
# Si tu túnel usa un dominio propio, indícalo (cloudflared no lo imprime):
# RITMIQ_TUNNEL_CUSTOM_URL=https://ritmiq.midominio.com
# Alternativa sin token (URL aleatoria que cambia en cada arranque):
# RITMIQ_TUNNEL_MODE=quick

# ── Supabase (publicar el endpoint del servidor + cache global) ──────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Credenciales del DUEÑO para publicar el endpoint del servidor en
# `tunnel_endpoints` (kind='server'), y así la PWA lo descubre sola.
# Usa email+password del dueño, o un access/refresh token.
RITMIQ_OWNER_EMAIL=
RITMIQ_OWNER_PASSWORD=
# RITMIQ_OWNER_ACCESS_TOKEN=
# RITMIQ_OWNER_REFRESH_TOKEN=
