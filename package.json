{
  "name": "ritmiq",
  "version": "0.1.0",
  "private": true,
  "description": "Ritmiq — Reproductor de música personal con streaming y descarga offline (Desktop + PWA)",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:desktop": "pnpm --filter @ritmiq/desktop dev",
    "dev:pwa": "pnpm --filter @ritmiq/pwa dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:push": "supabase db push",
    "supabase:fn:serve": "supabase functions serve",
    "test": "node --test apps/desktop/main/devices.test.js",
    "test:rebuild": "pnpm rebuild better-sqlite3 && node --test apps/desktop/main/devices.test.js && pnpm --filter @ritmiq/desktop run rebuild:native"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "supabase": "^2.0.0"
  },
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "supabase"
    ]
  }
}
